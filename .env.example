# Mollie API Settings (Get your key from mollie.com)
MOLLIE_API_KEY=your_mollie_api_key_here

# Email Settings (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_app_password_here
ADMIN_EMAIL=your_admin_email@example.com

# Telegram Settings (Get token from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# (Optional) Use a Telegram API proxy URL if your server (like InfinityFree) blocks api.telegram.org
# TELEGRAM_API_BASE=https://tapi.k1s.my.id/

# General Settings
SITE_URL=https://olddhakabiryani.site.je
