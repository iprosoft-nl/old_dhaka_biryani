# Mollie API Settings (Get your key from mollie.com)
MOLLIE_API_KEY=your_mollie_api_key_here

# Email Settings (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_smtp_app_password_here
ADMIN_EMAIL=your_admin_email@example.com

# WhatsApp Settings (Using a service like UltraMsg or Twilio)
WHATSAPP_API_URL=https://api.ultramsg.com/instanceXXXXX/messages/chat
WHATSAPP_TOKEN=your_whatsapp_token_here
ADMIN_WHATSAPP=+31600000000

# General Settings
SITE_URL=http://localhost/old_dhaka_biryani
